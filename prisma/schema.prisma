generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique @map("supabase_id")
  name       String
  username   String   @unique
  email      String   @unique
  phone      String?
  location   String?
  avatarUrl  String?  @map("avatar_url")
  role       Role     @default(STUDENT)
  plan       Plan     @default(FREE)
  level      Int      @default(1)
  streak     Int      @default(0)
  riskPct    Float    @default(0.5) @map("risk_pct")
  experience Experience @default(BEGINNER)
  instruments String[] // e.g. ["EURUSD","XAUUSD"]
  framework  String   @default("SMC") // "SMC" | "SnD"
  notifPrefs    Json?     @map("notif_prefs")
  privacyPrefs  Json?     @map("privacy_prefs")
  planExpiresAt DateTime? @map("plan_expires_at")
  welcomeEmailAt DateTime? @map("welcome_email_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  trades         Trade[]
  priceAlerts    PriceAlert[]
  badges         UserBadge[]
  lessonProgress LessonProgress[]
  posts          Post[]
  postLikes      PostLike[]
  postComments   PostComment[]
  subscriptions  Subscription[]
  alerts         Alert[]
  notifications  Notification[]

  @@map("users")
}

enum Role {
  STUDENT
  INSTRUCTOR
}

enum Plan {
  FREE
  PRO
  FUNDED
}

enum Experience {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Trades / Journal ────────────────────────────────────────────────────────

model Trade {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  date       DateTime    @default(now())
  pair       String      // EURUSD, XAUUSD, etc.
  direction  Direction
  model      String      // model name (SMC or SnD)
  framework  String      @default("SMC") // "SMC" | "SnD"
  session    Session?
  entryPrice Float?      @map("entry_price")
  stopLoss   Float?      @map("stop_loss")
  takeProfit Float?      @map("take_profit")
  rr         Float?      // planned R:R
  closePrice Float?      @map("close_price") // actual exit price
  pnlR       Float       @default(0) @map("pnl_r") // actual R outcome
  riskPct    Float       @default(0.5) @map("risk_pct")
  closedAt   DateTime?   @map("closed_at")
  result     TradeResult @default(OPEN)
  rating     Int         @default(3) // 1-5 execution rating
  discipline Boolean     @default(true)
  tags       String[]
  mistake    String?
  note       String?
  chartUrl   String?     @map("chart_url") // Supabase Storage URL
  fromAlert  String?     @map("from_alert") // alert id if copied
  aiReview   Json?       @map("ai_review")  // persisted Gavo review result

  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@map("trades")
}

enum Direction {
  LONG
  SHORT
}

enum Session {
  LONDON
  NEW_YORK
  ASIA
}

enum TradeResult {
  WIN
  LOSS
  OPEN
}

// ─── Instructor Alerts ───────────────────────────────────────────────────────

model Alert {
  id         String      @id @default(cuid())
  authorId   String?     @map("author_id")
  author     User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  pair       String
  direction  Direction
  status     AlertStatus @default(ACTIVE)
  title      String
  model      String
  session    Session?
  entryPrice Float       @map("entry_price")
  stopLoss   Float       @map("stop_loss")
  tp1        Float
  tp2        Float?
  rr         String      // e.g. "3.1R"
  tags       String[]
  note       String?
  reactions  Int         @default(0)
  taken      Int         @default(0)
  result     String?
  postedAt   DateTime    @default(now()) @map("posted_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@map("alerts")
}

enum AlertStatus {
  ACTIVE
  TP1
  TP2
  SL
  CANCELLED
  CLOSED
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  icon      String           @default("notifications_active") // material symbol name
  tone      String           @default("teal")                 // "teal" | "gold" | "coral"
  href      String?                                           // deep link, e.g. "/alerts"
  dedupeKey String?          @map("dedupe_key")               // idempotency key
  visibleAt DateTime         @default(now()) @map("visible_at") // delayed delivery (FREE 4h alert gate)
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@unique([userId, dedupeKey])
  @@index([userId, visibleAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

enum NotificationType {
  INSTRUCTOR_ALERT
  POST_LIKE
  POST_COMMENT
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PLAN_CANCELLED
  PLAN_EXPIRING
  PLAN_EXPIRED
  COURSE_COMPLETED
  COURSE_PUBLISHED
  SYSTEM
  MACRO_BIAS_FLIP
  COT_SIGNAL
}

// ─── Price Alerts ────────────────────────────────────────────────────────────

model PriceAlert {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pair      String
  condition String   // "crosses" | "above" | "below"
  price     Float
  note      String?
  triggered Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("price_alerts")
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan
  status          SubscriptionStatus @default(PENDING)
  lencoReference  String?            @unique @map("lenco_reference")
  currency        String             @default("ZMW") // "ZMW" | "USD"
  amountCents     Int                @map("amount_cents")
  billingCycle    String             @default("monthly") @map("billing_cycle") // "monthly" | "annual"
  startedAt       DateTime?          @map("started_at")
  renewsAt        DateTime?          @map("renews_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

// ─── Community ───────────────────────────────────────────────────────────────

model Post {
  id        String      @id @default(cuid())
  authorId  String      @map("author_id")
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text      String
  pair      String?
  dir       Direction?
  result    TradeResult?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  likes    PostLike[]
  comments PostComment[]

  @@map("posts")
}

model PostLike {
  id     String @id @default(cuid())
  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("post_comments")
}

// ─── Academy ─────────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  tier        String   @default("free")        // "free" | "pro" | "funded"
  icon        String   @default("school")
  color       String   @default("var(--teal)")
  level       Int      @default(1)
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lessons     Lesson[]

  @@map("courses")
}

model Lesson {
  id        String  @id @default(cuid())
  courseId  String? @map("course_id")
  course    Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  slug      String
  level     Int
  title     String
  duration  String  // e.g. "18 min"
  body      String? // markdown text content
  summary   String
  points    String[]
  videoUrl  String? @map("video_url")
  published Boolean @default(false)
  order     Int

  progress LessonProgress[]

  @@unique([courseId, slug])
  @@map("lessons")
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String   @map("lesson_id")
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed Boolean  @default(false)
  completedAt DateTime? @map("completed_at")

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ─── COT Data ────────────────────────────────────────────────────────────────

model CotReport {
  id              String   @id @default(cuid())
  pair            String   // "EURUSD" | "GBPUSD" | "NZDUSD" | "AUDUSD" | "XAUUSD" | "NAS100" | "DXY"
  reportDate      DateTime @map("report_date")
  largeSpecLong   Int?     @map("large_spec_long")
  largeSpecShort  Int?     @map("large_spec_short")
  largeSpecNet    Int      @map("large_spec_net")
  commercialLong  Int?     @map("commercial_long")
  commercialShort Int?     @map("commercial_short")
  commercialNet   Int      @map("commercial_net")
  smallSpecLong   Int?     @map("small_spec_long")
  smallSpecShort  Int?     @map("small_spec_short")
  smallSpecNet    Int      @map("small_spec_net")
  openInterest    Int?     @map("open_interest") // total contracts outstanding (unsigned, contract framing)
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([pair, reportDate])
  @@index([pair, reportDate(sort: Desc)])
  @@map("cot_reports")
}

// ─── FX Option Expiries ──────────────────────────────────────────────────────

model FxOptionExpiry {
  id         String   @id @default(cuid())
  expiryDate DateTime @map("expiry_date") // UTC midnight of the expiry day
  pair       String   // normalized: "EURUSD", "USDJPY", etc.
  spotPrice  String?  @map("spot_price")  // spot at time of fetch
  levels     Json     // FxLevel[] — see types/fx-orders.ts
  sourceUrl  String?  @map("source_url")  // InvestingLive page URL
  imageUrl   String?  @map("image_url")   // direct image URL that was parsed
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  @@unique([expiryDate, pair])
  @@index([expiryDate(sort: Desc)])
  @@index([pair, expiryDate(sort: Desc)])
  @@map("fx_option_expiries")
}

// ─── Trend Matrix ────────────────────────────────────────────────────────────

model TrendMatrix {
  id        String   @id  // always "singleton" — one shared record
  matrix    Json     // Record<pair, Record<tf, "bullish"|"bearish"|"ranging">>
  notes     Json     // Record<pair, string>
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") // instructor user id

  @@map("trend_matrix")
}

// ─── Instruments ─────────────────────────────────────────────────────────────

model Instrument {
  id           String   @id @default(cuid())
  symbol       String   @unique          // "EURUSD"
  label        String                    // "EUR/USD"
  category     String                    // "forex" | "commodity" | "index"
  tier         String   @default("major") // "major" | "minor" | "exotic"
  pipSize      Float                     // 0.0001 / 0.01 / 1
  pipValue     Float                     // USD value per pip per standard lot
  tdSymbol     String?  @map("td_symbol")       // Twelve Data: "EUR/USD", "IXIC"
  cotContract  String?  @map("cot_contract")     // CFTC label used in DB CotReport.pair (same as symbol)
  cotCode      String?  @map("cot_code")         // CFTC Socrata API contract code (e.g. "099741")
  cotMin52w    Float?   @map("cot_min52w")
  cotMax52w    Float?   @map("cot_max52w")
  cotMinC52w   Float?   @map("cot_min_c52w")
  cotMaxC52w   Float?   @map("cot_max_c52w")
  cotInverted  Boolean  @default(false) @map("cot_inverted") // true for USD-base pairs
  fxoTracked   Boolean  @default(false) @map("fxo_tracked")  // in FX option expiries
  active       Boolean  @default(true)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("instruments")
}

// ─── Plan pricing config ─────────────────────────────────────────────────────

model PlanConfig {
  planId     String   @id @map("plan_id")  // "free" | "pro" | "funded"
  monthlyZmw Int      @default(0)  @map("monthly_zmw")
  annualZmw  Int      @default(0)  @map("annual_zmw")
  monthlyUsd Int      @default(0)  @map("monthly_usd")
  annualUsd  Int      @default(0)  @map("annual_usd")
  updatedAt  DateTime @updatedAt   @map("updated_at")

  @@map("plan_configs")
}

// ─── Badges ──────────────────────────────────────────────────────────────────

model UserBadge {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  icon     String
  label    String
  tone     String // "teal" | "gold" | "coral"
  earnedAt DateTime @default(now()) @map("earned_at")

  @@map("user_badges")
}

// ─── MacroEdge — fundamental/macro analysis module ───────────────────────────
// Phase 1: economic calendar only (replaces the Tradays widget). IndicatorType
// is defined now (not just when Phase 2's rule engine lands) so EconomicEvent
// can tag its category from day one without a later migration.

enum IndicatorType {
  INTEREST_RATE
  CPI
  GDP
  EMPLOYMENT // NFP / claimant count / employment change, per currency
  RETAIL_SALES
  MANUFACTURING_PMI
  CONSUMER_CONFIDENCE
  TRADE_BALANCE
  BOND_YIELD_10Y
}

model EconomicEvent {
  id         String         @id @default(cuid())
  externalId String         @unique @map("external_id") // Finnhub event id
  currency   String // "USD" | "EUR" | "GBP" | "NZD" | "XAU"
  title      String
  category   IndicatorType? // mapped from Finnhub's free-text category via
  // src/lib/macro/indicatorMap.ts — null when no mapping matches
  impact     String // "high" | "medium" | "low"
  actual     String?
  forecast   String?
  previous   String?
  eventTime  DateTime  @map("event_time") // UTC
  releasedAt DateTime? @map("released_at") // when `actual` was first populated
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([currency, eventTime(sort: Desc)])
  @@index([eventTime])
  @@map("economic_events")
}

// Phase 2: FRED + World Bank indicator snapshots, deterministic scoring
// (Layers 2/3 of the MacroEdge plan). World Bank rows use the same table
// tagged source=WORLD_BANK with an annual periodDate rather than a parallel
// schema — see the plan's Layer 1 design notes.

enum DataSource {
  FINNHUB
  FRED
  WORLD_BANK
  MANUAL
}

model MacroIndicatorSnapshot {
  id             String        @id @default(cuid())
  currency       String
  indicatorType  IndicatorType @map("indicator_type")
  value          Float
  unit           String? // display only, e.g. "percent"
  periodDate     DateTime      @map("period_date") // period the data covers, not the release date
  source         DataSource
  releaseEventId String?       @map("release_event_id") // links to EconomicEvent.externalId when sourced from a calendar release
  fetchedAt      DateTime      @default(now()) @map("fetched_at")

  @@unique([currency, indicatorType, periodDate])
  @@index([currency, indicatorType, periodDate(sort: Desc)])
  @@map("macro_indicator_snapshots")
}

model CurrentCurrencyScore {
  currency   String   @id // one row per currency, upserted in place — "latest" only
  totalScore Float    @map("total_score")
  breakdown  Json // [{ indicatorType, signal (-2..2), weight, weightedContribution, reason }] — denormalized, see Layer 2 note in the plan
  computedAt DateTime @map("computed_at")
  inputHash  String   @map("input_hash") // hash of the snapshot values used — drives flip detection / future Gavo-regen

  @@map("current_currency_scores")
}

// Phase 4: Finnhub news feed. currency tagging is a keyword-match heuristic
// against currency/central-bank names (Finnhub's free news endpoint is
// mostly general market news, not curated forex-tagged content) — imperfect
// by design, not a blocker, per the plan's Hardest Parts section.
model NewsItem {
  id            String   @id @default(cuid())
  externalId    String   @unique @map("external_id")
  currency      String? // best-effort tag, null when no keyword matched
  headline      String
  summary       String?
  url           String
  source        String
  publishedAt   DateTime @map("published_at")
  fetchedAt     DateTime @default(now()) @map("fetched_at")

  @@index([currency, publishedAt(sort: Desc)])
  @@map("news_items")
}

// Phase 3: Layer 4 (pair bias) + Layer 6 (Gavo narration). Layer 5
// (confluence vs. TrendMatrix/COT/FX-Options) is deliberately NOT a table —
// it's a read-time comparison, see the plan's score-proliferation fix.

enum BiasLabel {
  STRONG_BUY
  BUY
  NEUTRAL
  SELL
  STRONG_SELL
}

enum SubjectType {
  PAIR
  CURRENCY
}

model CurrentPairBias {
  pair          String    @id
  baseCurrency  String    @map("base_currency")
  quoteCurrency String    @map("quote_currency")
  baseScore     Float     @map("base_score")
  quoteScore    Float     @map("quote_score")
  differential  Float
  biasLabel     BiasLabel @map("bias_label")
  computedAt    DateTime  @map("computed_at")
  inputHash     String    @map("input_hash")

  @@map("current_pair_biases")
}

model GavoMacroExplanation {
  id          String      @id @default(cuid())
  subjectType SubjectType @map("subject_type")
  subjectKey  String      @map("subject_key") // pair symbol or currency code
  explanation String
  model       String // e.g. "claude-sonnet-4-6"
  inputHash   String      @map("input_hash") // regenerate only when this differs from the current score's/bias's hash
  generatedAt DateTime    @default(now()) @map("generated_at")

  @@unique([subjectType, subjectKey])
  @@map("gavo_macro_explanations")
}

// Gavo COT Read — separate table from GavoMacroExplanation because that model
// is keyed by (SubjectType.PAIR, pair) for macro bias explanations; a COT
// read on the same pair would collide on the same unique constraint.
model GavoCotExplanation {
  id          String   @id @default(cuid())
  pair        String   @unique
  explanation String
  model       String // e.g. "claude-sonnet-4-6"
  inputHash   String   @map("input_hash") // regenerate only when the current COT reading differs
  generatedAt DateTime @default(now()) @map("generated_at")

  @@map("gavo_cot_explanations")
}
